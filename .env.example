# Copy this file to .dev.vars when running the Cloudflare Worker locally:
# cp .env.example .dev.vars
#
# Production values are shown by default. For production deploys, put
# SESSION_SECRET in Cloudflare with:
# bunx wrangler secret put SESSION_SECRET

# Required. Used to sign this tool's local session cookie.
# Use a long random value. Example generator:
# openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-secret

# Hub issuer expected in launch JWTs.
# Production:
# HUB_ISSUER=https://lawi-hub.lawi.workers.dev
# Local Hub example, if the Hub is running on Vite port 5173 and signs tokens
# with HUB_PUBLIC_URL=http://localhost:5173:
# HUB_ISSUER=http://localhost:5173
HUB_ISSUER=https://lawi-hub.lawi.workers.dev

# Optional. Defaults to: ${HUB_ISSUER}/.well-known/jwks.json
# Set this only when the JWKS endpoint is not under HUB_ISSUER, or when you
# tunnel/proxy the local Hub from another URL.
# HUB_JWKS_URL=https://lawi-hub.lawi.workers.dev/.well-known/jwks.json

# Optional. Defaults to: ${HUB_ISSUER}/tools/${TOOL_KEY}/launch
# Use this if the Hub launch route is hosted somewhere different from the
# issuer, or if you need an explicit local/tunnel URL.
# HUB_LAUNCH_URL=https://lawi-hub.lawi.workers.dev/tools/proposal-generator/launch

# Optional. Must match the Hub registry key and the JWT aud/toolKey claims.
# Keep this as proposal-generator unless you add another Hub registry entry.
TOOL_KEY=proposal-generator

# Optional. Local session cookie settings for this Worker.
# Default cookie name:
SESSION_COOKIE_NAME=proposal_generator_session

# Optional. Local session lifetime in seconds.
# Required behavior is 3600 seconds (60 minutes).
SESSION_MAX_AGE_SECONDS=3600
