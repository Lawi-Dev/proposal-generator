{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lawi-proposal-generator",
  "compatibility_date": "2025-06-01",

  // App estático (Vite SPA). Servido pela rede de Assets do Cloudflare — sem
  // Worker de back-end (a geração de PDF é client-side por enquanto).
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },

  "observability": { "enabled": true }
}
